{
  "name": "@cuebook/cli",
  "version": "0.1.0",
  "description": "Official command-line client for Cuebook's remote MCP server.",
  "type": "module",
  "bin": {
    "cuebook": "./dist/cli.js",
    "cbk": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run smoke && npm pack --dry-run",
    "format": "biome check --write .",
    "lint": "biome check .",
    "smoke": "node dist/cli.js --version",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuebook-public/cuebook-cli.git"
  },
  "homepage": "https://github.com/cuebook-public/cuebook-cli#readme",
  "bugs": {
    "url": "https://github.com/cuebook-public/cuebook-cli/issues"
  },
  "keywords": [
    "cuebook",
    "mcp",
    "ai-agent",
    "market-intelligence",
    "paper-trading"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
